# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database (leave empty to use SQLite locally) ──────────
DATABASE_URL=

# ── Supabase Storage (optional — leave empty for local file storage) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_REPORTS_BUCKET=lab-reports

# ── App Config ────────────────────────────────────────────
DEFAULT_LAB_NAME=Khulna Advanced Medical Institution
MASTER_CODE=CLINIC-2026-MASTER
CORS_ORIGINS=http://localhost:3000

# ── AI Model Config ───────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_HAIKU_MODEL=claude-haiku-4-5
HAIKU_MIN_VALUES=1
